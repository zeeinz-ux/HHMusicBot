# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_application_id
GUILD_ID=                               # optional — guild ID for fast command registration

# Spotify API Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Genius API Configuration (optional — lyrics work via web scraping without these)
GENIUS_CLIENT_ID=
GENIUS_CLIENT_SECRET=

# Bot Settings (optional)
EMBED_COLOR=#FF6B6B
SUPPORT_SERVER=https://discord.gg/ACJQzJuckW
# WEBSITE=https://beatra.app
STATUS=🎵 HHMusic | /play

# Sharding Settings (for bots with 1000+ servers)
TOTAL_SHARDS=auto
SHARD_LIST=auto
SHARD_MODE=process
SHARD_RESPAWN=true
SHARD_SPAWN_DELAY=5500
SHARD_SPAWN_TIMEOUT=30000

# YouTube Cookie Settings (optional — iOS client used by default on headless servers)
# COOKIES_FROM_BROWSER=chrome           # chrome, firefox, edge, safari
# COOKIES_FILE=./cookies.txt

# Proxy for yt-dlp (optional — bypass YouTube block on datacenter IPs)
# Format: http://user:pass@host:port or socks5://host:port
# YTDLP_PROXY=http://176.111.37.5:39811
